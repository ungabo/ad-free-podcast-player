#!/usr/bin/env sh
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
GRADLE_HOME="$SCRIPT_DIR/.tools/gradle/gradle-8.10.2"
JAVA_HOME="C:/Program Files/Unity/Hub/Editor/6000.4.6f1/Editor/Data/PlaybackEngines/AndroidPlayer/OpenJDK"
PATH="$JAVA_HOME/bin:$PATH"
export JAVA_HOME PATH
if [ ! -x "$GRADLE_HOME/bin/gradle" ]; then
  echo "Local Gradle distribution not found at $GRADLE_HOME" >&2
  exit 1
fi
exec "$GRADLE_HOME/bin/gradle" -p "$SCRIPT_DIR" "$@"
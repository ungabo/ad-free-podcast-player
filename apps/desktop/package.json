{
  "name": "desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Ad Free Podcast Player desktop shell",
  "author": "Ad Free Podcast Player",
  "main": "src/main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "sync:web": "node scripts/sync-web-ui.mjs",
    "package:win": "node scripts/sync-web-ui.mjs && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-win.ps1"
  },
  "devDependencies": {
    "@electron/get": "^2.0.3",
    "@electron/packager": "^18.3.2",
    "electron": "37.7.1",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.adfreepod.player.desktop",
    "productName": "Ad Free Podcast Player",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json",
      "!dist/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}

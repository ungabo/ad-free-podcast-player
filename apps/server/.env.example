APP_STORAGE=/srv/storage
DB_PATH=/srv/storage/jobs.sqlite
QUEUE_DIR=/srv/storage/queue
INPUT_DIR=/srv/storage/input
OUTPUT_DIR=/srv/storage/output
WORK_DIR=/srv/storage/work
ADFREE_CA_BUNDLE=

WORKER_POLL_SECONDS=2
PROCESSOR_MODE=adcutforge
FFMPEG_BIN=ffmpeg
SOURCE_CACHE_RETENTION_DAYS=60
SOURCE_DOWNLOAD_TIMEOUT_SECONDS=900

# Set these when using PROCESSOR_MODE=adcutforge
ADCUTFORGE_ROOT=/opt/adcutforge
ADCUTFORGE_PYTHON=python3
ADCUTFORGE_SCRIPT=
PARAKEET_PYTHON=
PARAKEET_MODEL=nvidia/parakeet-tdt-0.6b-v3
